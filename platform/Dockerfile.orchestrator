########################################################################
# Orchestrator — API server that routes work to Claude Code workers
# Verifies: dev-crew unified repo — Task 3 Step 1
# Build context: repo root (..), COPY paths are platform/orchestrator/ and platform/scripts/
########################################################################
FROM node:22-slim

ENV CLAUDE_NONINTERACTIVE=1

RUN apt-get update && apt-get install -y \
    curl git jq python3 \
    && rm -rf /var/lib/apt/lists/*

# Claude Code (for direct session execution)
RUN npm install -g @anthropic-ai/claude-code

WORKDIR /app

# Install orchestrator deps
COPY platform/orchestrator/package.json platform/orchestrator/package-lock.json* ./
RUN npm install --production

# Copy orchestrator code
COPY platform/orchestrator/ ./
COPY platform/scripts/ /app/scripts/
RUN chmod +x /app/scripts/*.sh \
    && sed -i 's/\r$//' /app/scripts/*.sh

# Copy worker build context so orchestrator can build the worker image at runtime
COPY platform/Dockerfile.worker /app/worker-build/platform/Dockerfile.worker
COPY platform/scripts/ /app/worker-build/platform/scripts/
COPY templates/ /app/worker-build/templates/

EXPOSE 8080

CMD ["node", "server.js"]
